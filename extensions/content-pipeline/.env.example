# ══════════════════════════════════════════════
# Content Pipeline + OpenClaw Gateway — ALL Keys
# One file for everything. Copy to .env and fill in.
# ══════════════════════════════════════════════

# ── LLM Providers (for content generation + gateway agent) ──
GOOGLE_AI_API_KEY=                   # https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY_1=               # Extra key from project 2
# GOOGLE_AI_API_KEY_2=               # Extra key from project 3
GROQ_API_KEY=                        # https://console.groq.com
OPENROUTER_API_KEY=                  # https://openrouter.ai
CEREBRAS_API_KEY=                    # https://cloud.cerebras.ai
MISTRAL_API_KEY=                     # https://console.mistral.ai
# ANTHROPIC_API_KEY=                 # https://console.anthropic.com (paid)

# ── YouTube OAuth ──
YOUTUBE_CLIENT_ID=                   # Google Cloud Console → Credentials → OAuth
YOUTUBE_CLIENT_SECRET=

# ── Facebook Page ──
FACEBOOK_PAGE_ID=                    # Your page → About → Page ID
FACEBOOK_PAGE_ACCESS_TOKEN=          # Graph Explorer → Get Page Token

# ── TikTok ──
# TIKTOK_COOKIES_PATH=~/.openclaw/tiktok-cookies.txt

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID=                       # dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=                    # R2 → Manage R2 API Tokens
R2_SECRET_ACCESS_KEY=
R2_BUCKET=openclaw-pipeline
R2_MAX_STORAGE_GB=8
R2_RETENTION_DAYS=30

# ── Discord Bot ──
DISCORD_BOT_TOKEN=                   # discord.com/developers → Bot → Token
DISCORD_APP_ID=                      # Application ID (for reference)
DISCORD_PUBLIC_KEY=                  # Public Key (for reference)
DISCORD_GUILD_ID=                    # Your server ID

# ── Google Service Account (auto API key generation) ──
# GOOGLE_SA_CLIENT_EMAIL=
# GOOGLE_SA_PRIVATE_KEY_B64=         # base64 of private key from JSON
# GOOGLE_SA_PROJECT_ID=

# ── OpenClaw Gateway ──
OPENCLAW_GATEWAY_MODE=local
OPENCLAW_GATEWAY_PORT=18789

# ── Zalo Bot (optional) ──
# ZALO_OA_ACCESS_TOKEN=
# ZALO_OA_SECRET_KEY=
# ZALO_APP_ID=
